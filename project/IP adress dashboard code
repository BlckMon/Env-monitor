// ---------------- WIFI CONNECT ----------------

void connectWiFi() {
  // Try saved WiFi first (if exists)
  if (wifi_ssid.length() > 0) {
    Serial.println("Trying saved WiFi...");
    WiFi.begin(wifi_ssid.c_str(), wifi_pass.c_str());

    unsigned long startAttempt = millis();
    while (WiFi.status() != WL_CONNECTED && millis() - startAttempt < 6000) {
      delay(300);
      Serial.print(".");
    }

    if (WiFi.status() == WL_CONNECTED) {
      Serial.println("\nConnected using saved WiFi!");
      return;
    }
  }

  // Fallback to hardcoded WiFi
  Serial.println("Connecting to hardcoded WiFi...");
  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(300);
    Serial.print(".");
  }

  Serial.println("\nConnected using hardcoded WiFi!");
}

// ---------------- SETUP / LOOP ----------------

void setup() {
  Serial.begin(115200);
  startMillis = millis();

  // SPIFFS
  if (!SPIFFS.begin(true)) {
    Serial.println("SPIFFS Mount Failed");
  }

  loadConfig();
  loadWiFiConfig();

  // BMP280
  if (!bmp.begin(0x76)) {
    Serial.println("BMP280 not found!");
  } else {
    Serial.println("BMP280 OK");
  }

  analogReadResolution(12);

  // WiFi
  connectWiFi();
  Serial.print("IP Address: ");
  Serial.println(WiFi.localIP());

  // MQTT
  mqtt.setServer(mqtt_server, 1883);

  // OTA
  ArduinoOTA.setHostname("ESP32_ENV_MONITOR");
  ArduinoOTA.begin();

  // ROUTES
  server.on("/", handleRoot);

  server.on("/settings", HTTP_GET, handleSettingsGet);
  server.on("/settings", HTTP_POST, handleSettingsPost);

  server.on("/log", handleLog);
  server.on("/logjson", handleLogJSONRoute);

  server.on("/api", handleAPIRoute);

  server.on("/calibrate", HTTP_POST, handleCalibrationRoute);

  server.on("/wifi", HTTP_POST, handleWiFiRoute);

  server.on("/ota", HTTP_GET, handleOTAFormRoute);
  server.on("/ota", HTTP_POST, []() {}, handleOTAUploadRoute);

  server.onNotFound(handleNotFound);

  server.begin();
  Serial.println("HTTP server started");
}

void loop() {
  ArduinoOTA.handle();
  mqtt.loop();
  server.handleClient();

  readSensors();
  logData();
  sendMQTT();
  sendQuestDB();   // now enabled

  delay(2000);     // ~2s update interval
}
