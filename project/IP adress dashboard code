#include <ArduinoOTA.h>
#include <Update.h>

Adafruit_BMP280 bmp;

const int MIC_PIN = 34;
const int MQ_PIN  = 35;

// ---------------- WIFI ----------------
const char* ssid     = "home wifi ";   // Your working 2.4 GHz network
const char* password = "1234567890";     // Your password

// ---------------- MQTT ----------------
WiFiClient espClient;
PubSubClient mqtt(espClient);
const char* mqtt_server = "broker.hivemq.com";

// ---------------- WEB SERVER ----------
WebServer server(80);

// ---------------- THRESHOLDS ----------
int noise_thr = 2000;
int air_thr   = 300;

// ---------------- GLOBAL VALUES -------
int micRaw = 0;
int mqRaw  = 0;
float temp = 0;
float pressure = 0;
unsigned long startMillis = 0;

// ======================= CONFIG (SPIFFS) =======================

void loadConfig() {
  if (!SPIFFS.exists("/config.txt")) {
    // No config yet, keep defaults
    return;
  }
  File f = SPIFFS.open("/config.txt", FILE_READ);
  if (!f) {
    return;
  }
  String line = f.readStringUntil('\n');
  f.close();

  int comma = line.indexOf(',');
  if (comma > 0) {
    noise_thr = line.substring(0, comma).toInt();
    air_thr   = line.substring(comma + 1).toInt();
  }
}

void saveConfig() {
  File f = SPIFFS.open("/config.txt", FILE_WRITE);
  if (!f) {
    return;
  }
  f.printf("%d,%d\n", noise_thr, air_thr);
  f.close();
}

// ======================= LOGGING =======================

void logData() {
  File f = SPIFFS.open("/log.csv", FILE_APPEND);
  if (!f) {
    return;
  }
  f.printf("%d,%d,%.2f,%.2f,%lu\n",
           micRaw, mqRaw, temp, pressure, millis());
  f.close();
}

// ======================= MQTT =======================

void sendMQTT() {
  if (!mqtt.connected()) {
    mqtt.connect("ESP32_ENV");
  }
  String payload = String(micRaw) + "," + String(mqRaw) + "," +
                   String(temp) + "," + String(pressure);
  mqtt.publish("shadrack/env", payload.c_str());
}

// ======================= QUESTDB (ILP) =======================

void sendQuestDB() {
  if (WiFi.status() != WL_CONNECTED) {
    return;
  }

  WiFiClient client;
  // Your Debian VM IP, ILP port 9009
  if (!client.connect("10.56.16.135", 9009)) {
    return;
  }

  // ILP line: table "env", tag device=esp32, fields
  String line = "env,device=esp32 ";
  line += "mic=" + String(micRaw);
  line += ",mq=" + String(mqRaw);
  line += ",temp=" + String(temp, 2);
  line += ",pressure=" + String(pressure, 2);
  line += "\n";

  client.print(line);
  client.stop();
}

// ======================= OFFSETS =======================

int mic_offset = 0;
int mq_offset  = 0;

// ---------------- SENSOR READ ----------------
void readSensors() {
  micRaw = analogRead(MIC_PIN) + mic_offset;
  mqRaw  = analogRead(MQ_PIN)  + mq_offset;

  temp = bmp.readTemperature();
  pressure = bmp.readPressure() / 100.0;
}

// ---------------- JSON API ----------------
void handleAPI() {
  String json = "{";
  json += "\"mic\":" + String(micRaw) + ",";
  json += "\"mq\":" + String(mqRaw) + ",";
  json += "\"temp\":" + String(temp) + ",";
  json += "\"pressure\":" + String(pressure) + ",";
  json += "\"noise_thr\":" + String(noise_thr) + ",";
  json += "\"air_thr\":" + String(air_thr) + ",";
  json += "\"mic_offset\":" + String(mic_offset) + ",";
  json += "\"mq_offset\":" + String(mq_offset) + ",";
  json += "\"uptime\":" + String((millis() - startMillis) / 1000);
  json += "}";
  server.send(200, "application/json", json);
}

// ---------------- HISTORICAL LOG VIEWER ----------------
void handleLogJSON() {
  if (!SPIFFS.exists("/log.csv")) {
    server.send(200, "application/json", "[]");
    return;
  }

  File f = SPIFFS.open("/log.csv", FILE_READ);
  if (!f) {
    server.send(200, "application/json", "[]");
    return;
  }

  String json = "[";
  bool first = true;

  while (f.available()) {
    String line = f.readStringUntil('\n');
    if (line.length() < 5) continue;

    int p1 = line.indexOf(',');
    int p2 = line.indexOf(',', p1 + 1);
    int p3 = line.indexOf(',', p2 + 1);
    int p4 = line.indexOf(',', p3 + 1);

    String mic = line.substring(0, p1);
    String mq  = line.substring(p1 + 1, p2);
    String t   = line.substring(p2 + 1, p3);
    String pr  = line.substring(p3 + 1, p4);
    String ts  = line.substring(p4 + 1);

    if (!first) json += ",";
    first = false;

    json += "{";
    json += "\"mic\":" + mic + ",";
    json += "\"mq\":" + mq + ",";
    json += "\"temp\":" + t + ",";
    json += "\"pressure\":" + pr + ",";
    json += "\"time\":" + ts;
    json += "}";
  }

  json += "]";
  f.close();

  server.send(200, "application/json", json);
}

// ---------------- CALIBRATION HANDLER ----------------
void handleCalibration() {
  if (server.hasArg("mic_offset")) {
    mic_offset = server.arg("mic_offset").toInt();
  }
  if (server.hasArg("mq_offset")) {
    mq_offset = server.arg("mq_offset").toInt();
  }

  server.sendHeader("Location", "/");
  server.send(303);
}

// ---------------- WIFI MANAGER (OPTION B) ----------------
// Stored credentials (optional override)
String wifi_ssid = "";
String wifi_pass = "";

void loadWiFiConfig() {
  if (!SPIFFS.exists("/wifi.txt")) return;

  File f = SPIFFS.open("/wifi.txt", FILE_READ);
  wifi_ssid = f.readStringUntil('\n');
  wifi_pass = f.readStringUntil('\n');
  wifi_ssid.trim();
  wifi_pass.trim();
  f.close();
}

void saveWiFiConfig(String s, String p) {
  File f = SPIFFS.open("/wifi.txt", FILE_WRITE);
  f.println(s);
  f.println(p);
  f.close();
}

void handleWiFiSave() {
  if (server.hasArg("ssid") && server.hasArg("pass")) {
    wifi_ssid = server.arg("ssid");
    wifi_pass = server.arg("pass");
    saveWiFiConfig(wifi_ssid, wifi_pass);
  }
  server.sendHeader("Location", "/");
  server.send(303);
}

// ---------------- OTA UPLOAD BACKEND ----------------
void handleOTAUpload() {
  HTTPUpload& upload = server.upload();

  if (upload.status == UPLOAD_FILE_START) {
    Serial.println("OTA Upload Start");
    if (!Update.begin(UPDATE_SIZE_UNKNOWN)) {
      Update.printError(Serial);
    }
  }
  else if (upload.status == UPLOAD_FILE_WRITE) {
    if (Update.write(upload.buf, upload.currentSize) != upload.currentSize) {
      Update.printError(Serial);
    }
  }
  else if (upload.status == UPLOAD_FILE_END) {
    if (Update.end(true)) {
      Serial.println("OTA Upload Success");
    } else {
      Update.printError(Serial);
    }
  }
}

void handleOTAForm() {
  String html = "<html><body><h1>OTA Upload</h1>";
  html += "<form method='POST' action='/ota' enctype='multipart/form-data'>";
  html += "<input type='file' name='firmware'><br><br>";
  html += "<input type='submit' value='Upload'>";
  html += "</form></body></html>";
  server.send(200, "text/html", html);
}

