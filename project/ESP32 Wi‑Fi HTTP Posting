[env:esp32-env-monitor]
platform = espressif32
board = esp32dev
framework = arduino

monitor_speed = 115200

lib_deps =
  adafruit/Adafruit BMP280 Library
  adafruit/Adafruit BME280 Library
  WiFi
  HTTPClient

ESP32 Firmware (Wi‑Fi + Sensors + HTTP POST)

src/main.cpp
#include <Arduino.h>
#include <WiFi.h>
#include <HTTPClient.h>
#include <Wire.h>
#include <Adafruit_BME280.h>
#include <Adafruit_BMP280.h>

#define I2C_SDA 21
#define I2C_SCL 22
#define MQ_PIN 34

// Wi-Fi credentials
const char* ssid = "YOUR_WIFI_SSID";
const char* password = "YOUR_WIFI_PASSWORD";

// QuestDB HTTP endpoint
String questURL = "http://YOUR_QUESTDB_IP:9000/exec";

Adafruit_BME280 bme;
Adafruit_BMP280 bmp;

bool hasBME = false;
bool hasBMP = false;

void connectWiFi() {
  WiFi.begin(ssid, password);
  Serial.print("Connecting to WiFi");

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("\nWiFi connected");
  Serial.println(WiFi.localIP());
}

void setupSensors() {
  Wire.begin(I2C_SDA, I2C_SCL);

  if (bme.begin(0x76)) {
    hasBME = true;
    Serial.println("BME280 detected");
  }

  if (bmp.begin(0x77)) {
    hasBMP = true;
    Serial.println("BMP280 detected");
  }

  analogReadResolution(12);
}

void sendToQuestDB(float t, float h, float p, int gas) {
  if (WiFi.status() != WL_CONNECTED) return;

  HTTPClient http;

  String query = "INSERT INTO env_monitor "
                 "(ts, temperature, humidity, pressure, gas_raw) VALUES "
                 "(now(), " + String(t) + ", " + String(h) + ", " + String(p) + ", " + String(gas) + ");";

  http.begin(questURL);
  http.addHeader("Content-Type", "text/plain");

  int code = http.POST(query);
  Serial.printf("QuestDB POST code: %d\n", code);

  http.end();
}

void setup() {
  Serial.begin(115200);
  connectWiFi();
  setupSensors();
}

void loop() {
  float temperature = NAN;
  float humidity = NAN;
  float pressure = NAN;
  int gas_raw = analogRead(MQ_PIN);

  if (hasBME) {
    temperature = bme.readTemperature();
    humidity = bme.readHumidity();
    pressure = bme.readPressure() / 100.0F;
  } else if (hasBMP) {
    temperature = bmp.readTemperature();
    pressure = bmp.readPressure() / 100.0F;
  }

  sendToQuestDB(temperature, humidity, pressure, gas_raw);

  delay(2000);
}

This is now a fully wireless environmental monitor.


QuestDB Table Schema (Wi‑Fi Compatible)

Run this in QuestDB’s web console:
CREATE TABLE env_monitor (
    ts TIMESTAMP,
    temperature DOUBLE,
    humidity DOUBLE,
    pressure DOUBLE,
    gas_raw INT
) TIMESTAMP(ts);

